# GitHub 个人访问令牌（拉私有库必填）：https://github.com/settings/tokens
#
# 经典令牌（Personal access tokens classic）：勾选「repo」，即可读你有权限的私有仓库的提交 API。
# 细粒度令牌（Fine-grained）：创建时选择能访问的组织/仓库，勾选 Contents: Read、Metadata: Read。
# 组织仓库若开了 SAML SSO，生成令牌后还要在令牌页对该组织点「Authorize」。
# 不配或权限不足时，私有库会 404；仅公开库可用 public_repo 或匿名（易触发 API 速率限制）。
GITHUB_TOKEN=

# 可选：按仓库使用不同 Token（一行 JSON）。键为小写 owner/repo；可用 "owner/*" 表示该 owner 下未单独列出的仓库。
# 匹配顺序：精确仓库 → owner/* → 上面的 GITHUB_TOKEN。值勿含未转义双引号；复杂时可改用 github_token_repo_map_json 键名。
# GITHUB_TOKEN_REPO_MAP={"acme/secret-app":"ghp_xxx","otherorg/api":"github_pat_yyy","acme/*":"ghp_acme_default"}

# 同步时为每条「新」GitHub 提交再请求一次详情 API，用于周报/成员习惯里的「代码改动画像」标签（语言/缩进启发式等）；会显著增加 API 次数
# GITHUB_COMMIT_STYLE_FETCH=true
# 单次同步最多拉取多少条详情（控制额度）；超出部分新提交仍会入库但不带画像，可下次再同步
# GITHUB_COMMIT_STYLE_MAX_PER_SYNC=400

# 仓库中心：克隆/拉取合并列表中的仓库到此目录（相对 backend 目录或绝对路径），默认 data/repo_mirrors（已在 .gitignore）
# REPO_MIRROR_ROOT=data/repo_mirrors
# CodeCommit 镜像：git 会调用 aws codecommit credential-helper；pip install -r requirements.txt 已包含 awscli（装在 .venv 即可）

# —— 数据库 ——
# 不配数据库：用 SQLite，数据在 backend/data/promanager.db（目录会自动创建）。
#
# MySQL 任选一种写法（分项与 DATABASE_URL 同时存在时：分项填全则优先分项，整行 URL 不会覆盖）：
# A) 分项（推荐：密码可含 @、# 等；# 在值里时请用引号，否则会被当成注释截断）：
# DB_HOST=127.0.0.1
#   ↑ 填「MySQL 服务器」的地址（你要连到哪台机器）。不是填你本机 IP。
#   若报错 Access denied for user 'u'@'某公网IP'，末尾 IP 是服务器看到的「客户端来源」，
#   需在 MySQL 里给该用户授权（如 'u'@'%'），而不是改 DB_HOST。
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=你的密码
# DB_NAME=promanager
# B) 或一行 DATABASE_URL（密码含 @# 需 URL 编码）：
# DATABASE_URL=mysql+pymysql://root:密码@127.0.0.1:3306/promanager?charset=utf8mb4
# 须先建库：CREATE DATABASE promanager CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;

# —— AWS CodeCommit（可选；与 GitHub 可同时用）——
# IAM 需 codecommit:ListRepositories、BatchGetRepositories（可选，用于列表页展示描述/克隆地址）、
# GetBranch、ListBranches、GetCommit 等读权限。
# 仓库在 DEFAULT_REPOS / 前端导入中写：cc:区域/仓库名 或 cc:区域/仓库名@分支
# 若密钥曾泄露，请在 IAM 停用并换新，勿提交本文件中的真实 Key。
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1

# —— 要同步的仓库（GitHub 与 CodeCommit 均可；多处配置会合并去重）——
# ① 推荐：前端「同步」页批量导入数据库（表 tracked_repos，API：GET/POST /api/repos）
# ② 本文件 DEFAULT_REPOS 或 REPOS_FILE（适合只跑后端、CI）
#
# 方式 A：环境变量，逗号、分号、换行分隔（多行可用引号包一整段）
DEFAULT_REPOS=myorg/frontend,myorg/api
#
# 方式 B：仓库很多时，用文件每行一个 owner/repo（# 行为注释）
# 复制 repos.example.txt 为 repos.txt 后编辑，并取消下一行注释：
# REPOS_FILE=repos.txt

# 可选：固定团队成员 GitHub 登录名（小写），逗号分隔；不填则从已同步提交中推断
TEAM_MEMBERS=alice,bob

# 同步后是否根据提交作者自动创建「成员档案」（默认 true）；设为 false 则只写入提交、不自动建档
# AUTO_PROVISION_CONTRIBUTORS=true

# —— CORS（仅当前端与 API 不同源时必填，例如页面在 https://pm.example.com、接口在另一子域）——
# 逗号分隔，勿尾逗号。同源访问（Nginx 反代到同一域名、或直接打开 :8000 静态页）可不配。
# CORS_ORIGINS=https://pm.example.com,https://www.example.com

# —— 后台定时同步（与 POST /api/sync 且 repos 为空相同：合并数据库已启用仓库 + DEFAULT_REPOS / REPOS_FILE）——
# DEFAULT_SINCE_DAYS=15
# BACKGROUND_SYNC_ENABLED=true
# BACKGROUND_SYNC_INTERVAL_HOURS=4
# 进程启动后延迟多久跑第一次（秒），避免与手动同步抢资源
# BACKGROUND_SYNC_INITIAL_DELAY_SECONDS=60
